<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#4c1d95"/>
      <stop offset="100%" stop-color="#1e1b4b"/>
    </linearGradient>
    <linearGradient id="glow" x1="0%" y1="100%" x2="100%" y2="0%">
      <stop offset="0%" stop-color="#7c3aed" stop-opacity="0"/>
      <stop offset="50%" stop-color="#7c3aed" stop-opacity="0.15"/>
      <stop offset="100%" stop-color="#a78bfa" stop-opacity="0"/>
    </linearGradient>
    <clipPath id="rounded">
      <rect width="512" height="512" rx="64" ry="64"/>
    </clipPath>
  </defs>
  
  <!-- Background -->
  <rect width="512" height="512" fill="url(#bg)" clip-path="url(#rounded)"/>
  
  <!-- Subtle glow behind dog -->
  <ellipse cx="256" cy="260" rx="140" ry="140" fill="url(#glow)"/>
  
  <!-- Husky silhouette -->
  <g transform="translate(256,270)" fill="#fafafa" opacity="0.95">
    <!-- Head base -->
    <ellipse cx="0" cy="-10" rx="58" ry="52" fill="#1a1a2e"/>
    
    <!-- Mask/face pattern - lighter area -->
    <ellipse cx="0" cy="-5" rx="40" ry="38" fill="#a1a1aa"/>
    
    <!-- Cheeks -->
    <ellipse cx="-30" cy="5" rx="22" ry="20" fill="#1a1a2e"/>
    <ellipse cx="30" cy="5" rx="22" ry="20" fill="#1a1a2e"/>
    
    <!-- Eyes -->
    <ellipse cx="-18" cy="-12" rx="8" ry="7" fill="#7c3aed"/>
    <ellipse cx="18" cy="-12" rx="8" ry="7" fill="#7c3aed"/>
    
    <!-- Eye shine -->
    <ellipse cx="-16" cy="-14" rx="2.5" ry="2" fill="#c4b5fd"/>
    <ellipse cx="20" cy="-14" rx="2.5" ry="2" fill="#c4b5fd"/>
    
    <!-- Snout -->
    <ellipse cx="0" cy="12" rx="22" ry="16" fill="#e4e4e7"/>
    
    <!-- Nose -->
    <ellipse cx="0" cy="8" rx="8" ry="5" fill="#09090b"/>
    
    <!-- Left ear -->
    <polygon points="-40,-52 -55,-105 -25,-70" fill="#1a1a2e"/>
    <polygon points="-37,-55 -48,-90 -28,-68" fill="#a1a1aa"/>
    
    <!-- Right ear -->
    <polygon points="40,-52 55,-105 25,-70" fill="#1a1a2e"/>
    <polygon points="37,-55 48,-90 28,-68" fill="#a1a1aa"/>
    
    <!-- Inner ear -->
    <polygon points="-35,-60 -43,-82 -28,-65" fill="#fef08a" opacity="0.3"/>
    <polygon points="35,-60 43,-82 28,-65" fill="#fef08a" opacity="0.3"/>
    
    <!-- Mouth line -->
    <path d="M-10,16 Q0,24 10,16" fill="none" stroke="#09090b" stroke-width="1.5" stroke-linecap="round"/>
    
    <!-- Whisker dots -->
    <circle cx="-14" cy="14" r="1" fill="#09090b"/>
    <circle cx="14" cy="14" r="1" fill="#09090b"/>
    
    <!-- Eyebrows -->
    <path d="M-28,-22 Q-18,-27 -10,-22" fill="none" stroke="#09090b" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M28,-22 Q18,-27 10,-22" fill="none" stroke="#09090b" stroke-width="1.5" stroke-linecap="round"/>
  </g>
  
  <!-- Brand letter mark -->
  <text x="256" y="440" font-family="'Inter',-apple-system,sans-serif" font-size="22" font-weight="700" fill="#a1a1aa" text-anchor="middle" letter-spacing="8">SIMONAI</text>
  
  <!-- Purple accent line -->
  <rect x="206" y="448" width="100" height="2" rx="1" fill="#7c3aed"/>
</svg>
